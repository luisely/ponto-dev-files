{
  "name": "ponto",
  "version": "1.0.0",
  "type": "module",
  "main": "main.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build:html:process": "node scripts/process-html.js",
    "build:js": "esbuild src/main.ts --bundle --minify --outdir=dist --entry-names=[name]-[hash] --asset-names=assets/[name]-[hash] --loader:.css=css --metafile=dist/meta.json",
    "build:css": "npx @tailwindcss/cli -i ./css/main.css -o ./css/output.css --minify",
    "build:prod": "npm run clean && npm run build:css && npm run build:js && npm run build:html:process && node scripts/copy-static-files.js",
    "dev:html": "cpy index.html dev && onchange \"index.html\" -- cpy index.html dev",
    "dev:js": "esbuild src/main.ts --bundle --outfile=dev/bundle.js --watch",
    "dev:css": "npx @tailwindcss/cli -i ./css/main.css -o ./dev/output.css --watch",
    "dev:serve": "http-server dev -p 3000 -a 0.0.0.0 --cors -c-1",
    "dev": "concurrently \"npm run dev:js\" \"npm run dev:css\" \"npm run dev:html\" \"npm run dev:serve\""
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "axios": "^1.18.1",
    "esbuild": "0.28.1",
    "lucide": "^1.24.0",
    "rimraf": "^6.1.3",
    "toastify-js": "^1.12.0",
    "vanillajs-datepicker": "^1.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/jest": "30.0.0",
    "@types/toastify-js": "1.12.4",
    "@types/vanillajs-datepicker": "1.3.5",
    "concurrently": "^10.0.3",
    "cpy-cli": "7.0.0",
    "http-server": "14.1.1",
    "onchange": "7.1.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2"
  }
}
