{
  "name": "ponto",
  "version": "1.0.0",
  "type": "module",
  "main": "main.ts",
  "scripts": {
    "clean": "rimraf dist",
    "build:html:process": "node scripts/process-html.js",
    "build:js": "esbuild src/main.ts --bundle --minify --outdir=dist --entry-names=[name]-[hash] --asset-names=assets/[name]-[hash] --loader:.css=css --metafile=dist/meta.json",
    "build:css": "npx @tailwindcss/cli -i ./css/main.css -o ./css/output.css --minify",
    "build:prod": "npm run clean && npm run build:css && npm run build:js && npm run build:html:process",
    "dev:html": "cpy index.html dev && onchange \"index.html\" -- cpy index.html dev",
    "dev:js": "esbuild src/main.ts --bundle --outfile=dev/bundle.js --watch",
    "dev:css": "npx @tailwindcss/cli -i ./css/main.css -o ./dev/output.css --watch",
    "dev": "concurrently \"npm run dev:js\" \"npm run dev:css\" \"npm run dev:html\"",
    "deploy": "npm run build:prod && cd dist && git add . && git commit -m \"Deploy\" && git push",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@types/toastify-js": "^1.12.4",
    "@types/vanillajs-datepicker": "^1.3.5",
    "axios": "^1.13.2",
    "lucide": "^1.21.0",
    "tailwindcss": "^4.1.13",
    "toastify-js": "^1.12.0",
    "vanillajs-datepicker": "^1.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@tailwindcss/cli": "^4.1.18",
    "@types/jest": "30.0.0",
    "concurrently": "^9.2.1",
    "cpy-cli": "^6.0.0",
    "esbuild": "0.28.1",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.2",
    "ts-jest": "29.4.6",
    "typescript": "^5.9.3"
  }
}
