{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		},
		"strict": true,
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2020"],
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["src"]
}
